{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@8.2"
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}